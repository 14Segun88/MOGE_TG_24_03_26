# Путь к JSON-маппингу для /compare/preset
MAPPING_FILE_PATH=mapping_PZ_ZnP.json

# Настройки сервера
HOST=0.0.0.0
PORT=8000
RELOAD=false
LOG_LEVEL=info

# Папка для сохранения отчётов (создаётся автоматически).
# Каждый запрос создаёт подпапку <YYYYMMDD>/<uuid>/ со всеми файлами:
#   report.json, report.html, validation.json, validation.html, pz.xml, znp.xml
# Оставьте пустым, чтобы отключить сохранение на диск.
REPORTS_DIR=reports

# Ограничения файлов
MAX_XML_SIZE_BYTES=52428800    # 50 МБ
MAX_MAPPING_SIZE_BYTES=10485760 # 10 МБ
