# =============================================================
# Конфигурация системы — МособлГосЭкспертиза DocumentAnalyzer v2.0
# =============================================================
# Скопируйте этот файл в .env и заполните свои ключи:
#   cp .env.example .env
# =============================================================

# ── Telegram Bot ──────────────────────────────────────────────
# Получить токен: @BotFather → /newbot
BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Telegram ID администратора (для получения логов)
ADMIN_TELEGRAM_ID=YOUR_TELEGRAM_ID_HERE

# ── Groq API ─────────────────────────────────────────────────
# Получить на: https://console.groq.com/
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE

# ── LM Studio (локальная модель для RAG-эмбеддингов) ─────────
# Адрес LM Studio (обычно Windows-хост из WSL)
LM_STUDIO_URL=http://172.31.128.1:1234/v1
# API-ключ LM Studio (если включена авторизация)
LM_STUDIO_API_KEY=lm-studio
# Модель для генерации (RAG ask)
LM_STUDIO_MODEL=qwen2.5-3b-instruct

# ── XSD-схема ────────────────────────────────────────────────
XSD_VERSION=01.06

# ── Режим работы ─────────────────────────────────────────────
# debug | production
APP_ENV=debug
